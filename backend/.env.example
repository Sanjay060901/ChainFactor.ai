# ChainFactor AI - Backend Environment Variables
# Copy to .env and fill in values

# Application
APP_ENV=development
DEBUG=true

# CORS (comma-separated origins)
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://chainfactor:chainfactor@localhost:5432/chainfactor

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS (primary region -- all services except Bedrock)
AWS_REGION=ap-south-1

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# S3
S3_BUCKET_NAME=
S3_INVOICE_PREFIX=invoices/

# Bedrock
BEDROCK_REGION=us-east-1
BEDROCK_SONNET_MODEL_ID=us.anthropic.claude-sonnet-4-6-v1
BEDROCK_OPUS_MODEL_ID=us.anthropic.claude-opus-4-6-v1
BEDROCK_HAIKU_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001

# Algorand
ALGORAND_NETWORK=testnet
ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_APP_WALLET_MNEMONIC=
ALGORAND_APP_ID=0

# Pera Explorer
PERA_EXPLORER_BASE_URL=https://testnet.explorer.perawallet.app
